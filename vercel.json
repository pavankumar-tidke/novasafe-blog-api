{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/[[...path]].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api/$1" },
    { "source": "/sitemap.xml", "destination": "/api/seo/sitemap" },
    { "source": "/robots.txt", "destination": "/api/seo/robots" },
    { "source": "/feed.xml", "destination": "/api/seo/feed" },
    { "source": "/rss.xml", "destination": "/api/seo/feed" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ]
}
