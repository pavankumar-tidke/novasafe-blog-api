# MongoDB Atlas (credentials built into connection string at runtime)
MONGODB_USERNAME=your-db-user
MONGODB_PASSWORD=your-db-password
MONGODB_HOST=cluster0.xxxxx.mongodb.net
MONGODB_OPTIONS=retryWrites=true&w=majority
DATABASE_NAME=blog_cms

# JWT
JWT_SECRET=change-me-min-32-chars
JWT_ISSUER=novasafe-blog-api
JWT_AUDIENCE=novasafe-blog-admin
JWT_ACCESS_TTL_SECONDS=3600

# API
API_BASE_PATH=/api
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,https://admin.novasafe.io,https://novasafe.io

# Site (SEO feeds)
SITE_URL=http://localhost:8080
SITE_NAME=NovaSafe Blog
SITE_DESCRIPTION=Security insights and updates from the NovaSafe team.

# Media
MEDIA_MAX_BYTES=5242880
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,image/avif
MEDIA_STORAGE_PATH=./uploads

# Admin login (until D1 admins table is migrated)
ADMIN_EMAIL=admin@novasafe.io
ADMIN_PASSWORD=change-me
